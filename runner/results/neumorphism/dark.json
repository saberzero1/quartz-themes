{
  ".status-bar": {
    "background": "rgb(28, 28, 28) none repeat scroll 0% 0% / auto padding-box border-box",
    "background-color": "rgb(28, 28, 28)",
    "border": "1px solid rgb(54, 54, 54)",
    "border-bottom": "1px solid rgb(54, 54, 54)",
    "border-bottom-left-radius": "10px",
    "border-bottom-right-radius": "10px",
    "border-bottom-width": "1px",
    "border-radius": "10px",
    "border-right": "1px solid rgb(54, 54, 54)",
    "border-right-width": "1px",
    "border-top-left-radius": "10px",
    "border-top-right-radius": "10px",
    "border-width": "1px"
  },
  ".view-content": {
    "background": "rgb(28, 28, 28) none repeat scroll 0% 0% / auto padding-box border-box",
    "background-color": "rgb(28, 28, 28)"
  },
  "div.mod-horizontal.mod-left-split.mod-sidedock.workspace-split": {
    "background": "rgb(28, 28, 28) none repeat scroll 0% 0% / auto padding-box border-box",
    "background-color": "rgb(28, 28, 28)",
    "gap": "16px",
    "margin": "16px 0px 0px",
    "margin-top": "16px"
  },
  "div.mod-horizontal.mod-right-split.mod-sidedock.workspace-split": {
    "background": "rgb(28, 28, 28) none repeat scroll 0% 0% / auto padding-box border-box",
    "background-color": "rgb(28, 28, 28)",
    "border-bottom-left-radius": "10px",
    "border-bottom-right-radius": "10px",
    "border-radius": "10px",
    "border-top-left-radius": "10px",
    "border-top-right-radius": "10px",
    "box-shadow": "rgb(10, 10, 10) 8px 8px 32px 0px, rgb(17, 17, 17) -8px -8px 32px 0px",
    "gap": "0px",
    "margin": "16px 16px 0px 0px",
    "margin-right": "16px",
    "margin-top": "16px"
  },
  "div.workspace-leaf": {
    "background": "rgb(28, 28, 28) none repeat scroll 0% 0% / auto padding-box border-box",
    "background-color": "rgb(28, 28, 28)",
    "border-bottom-left-radius": "10px",
    "border-bottom-right-radius": "10px",
    "border-radius": "10px",
    "border-top-left-radius": "10px",
    "border-top-right-radius": "10px",
    "box-shadow": "rgb(10, 10, 10) 8px 8px 32px 0px, rgb(17, 17, 17) -8px -8px 32px 0px"
  },
  "hr": {
    "opacity": "0"
  },
  "hr.workspace-leaf-resize-handle": {
    "opacity": "0"
  },
  "img": {
    "border-bottom-left-radius": "10px",
    "border-bottom-right-radius": "10px",
    "border-radius": "10px",
    "border-top-left-radius": "10px",
    "border-top-right-radius": "10px"
  }
}