    "dataAttr": null,
    "quartzSelector": "p",
    "properties": ["color", "font-family", "font-weight", "line-height"]
  },
  "text:strong": {
    "matchBy": "tag",
    "dataAttr": null,
    "quartzSelector": ".page article p > strong, strong",
    "properties": ["color", "font-family", "font-weight"]
  },
  "text:emphasis": {
    "matchBy": "tag",
    "dataAttr": null,
    "quartzSelector": ".page article p > em, em",
