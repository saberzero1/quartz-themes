    "max-width": "var(--metadata-max-width)"
  },
  "div.is-clickable.mod-collapsible.nav-folder-title.tree-item-self[data-path=\"folder/collapsed\"]": {
    "color": "var(--folder-open-text-color)",
    "cursor": "var(--cursor)",
    "font-size": "var(--nav-item-size)",
    "font-weight": "var(--nav-item-weight)",
