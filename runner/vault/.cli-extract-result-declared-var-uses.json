{
  "div.mod-active.workspace-leaf": {
    "background-color": "var(--background-primary)",
    "color": "var(--file-header-color-active)"
  },
  "div.workspace-leaf": {
    "background-color": "var(--background-secondary)"
  },
  "div.mod-horizontal.mod-left-split.mod-sidedock.workspace-split": {
    "background-color": "var(--tab-container-background)"
  },
  "div.mod-horizontal.mod-right-split.mod-sidedock.workspace-split": {
    "background-color": "var(--tab-container-background)"
  },
  "hr.workspace-leaf-resize-handle": {
    "height": "var(--divider-vertical-height)",
    "width": "var(--divider-width-hover)"
  },
  "p": {
    "color": "var(--text-muted)"
  },
  "hr": {
    "height": "var(--divider-vertical-height)",
    "width": "var(--divider-width-hover)"
  },
  "input[type=\"search\"]": {
    "color": "var(--text-normal)",
    "font-size": "var(--font-ui-small)",
    "height": "var(--input-height)"
  },
  "div.inline-title": {
    "color": "var(--inline-title-color)",
    "font-family": "var(--inline-title-font)",
    "font-size": "var(--inline-title-size)",
    "font-style": "var(--inline-title-style)",
    "font-weight": "var(--inline-title-weight)",
    "line-height": "var(--inline-title-line-height)",
    "text-align": "var(--inline-title-position)"
  },
  "div.is-clickable.mod-collapsible.tree-item-self": {
    "color": "var(--folder-open-text-color)",
    "cursor": "var(--cursor)",
