{
  "div.mod-active.workspace-leaf": {
    "background-color": "var(--background-primary)"
  },
  "div.workspace-leaf": {
    "background-color": "var(--background-secondary)"
  },
  "div.mod-horizontal.mod-left-split.mod-sidedock.workspace-split": {
    "background-color": "var(--tab-container-background)"
  },
  "div.mod-horizontal.mod-right-split.mod-sidedock.workspace-split": {
    "background-color": "var(--tab-container-background)"
  },
  "hr.workspace-leaf-resize-handle": {
    "height": "var(--divider-vertical-height)",
    "width": "var(--divider-width-hover)"
  },
  "p": {
    "color": "var(--text-muted)"
  },
  "hr": {
    "height": "var(--divider-vertical-height)",
    "width": "var(--divider-width-hover)"
  },
  "input[type=\"search\"]": {
    "background-color": "rgb(from var(--color-base-00) r g b/0.3)",
    "box-shadow": "inset 0 2px 4px rgb(from var(--mono-rgb-0) r g b/0.1)",
    "color": "var(--text-normal)",
    "font-size": "var(--font-ui-small)",
    "height": "var(--input-height)"
  },
  "div.inline-title": {
    "color": "var(--inline-title-color)",
    "font-family": "var(--inline-title-font)",
    "font-size": "var(--inline-title-size)",
    "font-style": "var(--inline-title-style)",
    "font-weight": "var(--inline-title-weight)",
    "line-height": "var(--inline-title-line-height)"
  },
  "div.is-clickable.mod-collapsible.tree-item-self": {
    "color": "var(--nav-item-color)",
    "cursor": "var(--cursor)",
    "font-size": "var(--nav-item-size)",
    "font-weight": "var(--nav-item-weight)",
    "line-height": "var(--line-height-tight)",
    "margin-bottom": "var(--nav-item-margin-bottom)"
  },
  "body.styled-scrollbars": {
    "background-color": "var(--background-primary)",
    "caret-color": "var(--caret-color)",
    "color": "var(--text-normal)",
    "font-family": "var(--font-interface)",
    "font-size": "var(--font-ui-medium)",
    "line-height": "var(--line-height-tight)"
  },
  "svg.lucide-alert-triangle.svg-icon": {
    "opacity": "var(--icon-opacity)",
    "height": "var(--icon-size)",
    "width": "var(--icon-size)"
  },
  "svg.lucide-x.svg-icon": {
    "height": "var(--icon-size)",
    "width": "var(--icon-size)"
  },
  "svg.lucide-list.svg-icon": {
    "height": "var(--icon-size)",
    "width": "var(--icon-size)"
  },
  ".metadata-container": {
    "background-color": "var(--metadata-background)",
    "color": "var(--text-muted)",
    "display": "var(--metadata-display-reading)",
    "transform": "translateX(calc(var(--size-4-1) * -1 * var(--direction)))",
    "max-width": "var(--metadata-max-width)"
  },
  ".metadata-container .metadata-property": {
    "background-color": "var(--metadata-property-background)",
    "box-shadow": "var(--metadata-property-box-shadow)"
  },
  ".metadata-property-key": {
    "background-color": "var(--metadata-label-background)",
    "font-family": "var(--metadata-label-font)",
    "min-width": "var(--metadata-label-width)",
    "width": "var(--metadata-label-width)"
  },
  ".metadata-property-value": {
    "background-color": "var(--metadata-input-background)",
    "font-family": "var(--metadata-input-font)",
    "min-height": "var(--input-height)"
  },
  "input[type=\"text\"]": {
    "background-color": "rgb(from var(--color-base-00) r g b/0.3)",
    "box-shadow": "inset 0 2px 4px rgb(from var(--mono-rgb-0) r g b/0.1)",
    "color": "var(--text-normal)",
    "font-size": "var(--font-ui-small)",
    "font-weight": "var(--metadata-label-font-weight)",
    "height": "var(--input-height)"
  },
  "div.is-clickable.mod-collapsible.nav-folder-title.tree-item-self[data-path=\"folder/collapsed\"]": {
    "color": "var(--nav-item-color)",
    "cursor": "var(--cursor)",
    "font-size": "var(--nav-item-size)",
    "font-weight": "var(--nav-item-weight)",
    "line-height": "var(--line-height-tight)",
    "margin-bottom": "var(--nav-item-margin-bottom)"
  },
  "div.is-clickable.mod-collapsible.nav-folder-title.tree-item-self[data-path=\"folder\"]": {
    "color": "var(--nav-item-color)",
    "cursor": "var(--cursor)",
    "font-size": "var(--nav-item-size)",
    "font-weight": "var(--nav-item-weight)",
    "line-height": "var(--line-height-tight)",
    "margin-bottom": "var(--nav-item-margin-bottom)"
  },
  ".nav-folder-title-content": {
    "color": "var(--text-normal)"
  },
  ".nav-files-container": {
    "padding-bottom": "max(var(--safe-area-inset-bottom), var(--size-4-6))"
  },
  ".clickable-icon.graph-controls-button": {
    "color": "var(--text-muted)",
    "cursor": "var(--cursor)"
  },
  ".status-bar": {
    "background-color": "var(--status-bar-background)",
    "color": "var(--status-bar-text-color)",
    "font-size": "var(--status-bar-font-size)",
    "padding-right": "var(--size-4-2)",
    "position": "var(--status-bar-position)"
  },
  ".status-bar-item": {
    "color": "var(--text-normal)",
    "cursor": "var(--cursor)"
  },
  ".nav-file-title": {
    "color": "var(--nav-item-color)",
    "cursor": "var(--cursor)",
    "font-size": "var(--nav-item-size)",
    "font-weight": "var(--nav-item-weight)",
    "line-height": "var(--line-height-tight)",
    "margin-bottom": "var(--nav-item-margin-bottom)"
  },
  ".clickable-icon": {
    "color": "var(--text-muted)",
    "cursor": "var(--cursor)"
  },
  ".clickable-icon svg": {
    "opacity": "var(--icon-opacity)",
    "height": "var(--icon-size)",
    "width": "var(--icon-size)"
  },
  ".view-header-breadcrumb-separator": {
    "color": "var(--text-faint)"
  },
  ".view-header-title": {
    "color": "var(--text-normal)"
  },
  ".view-content": {
    "background-color": "var(--color-base-25)",
    "box-shadow": "var(--ulu-glass-inset-tl-light), var(--ulu-glass-inset-br-light),\n        var(--ulu-glass-ring-light)",
    "padding-bottom": "max(var(--safe-area-inset-bottom), var(--size-4-8))",
    "height": "calc(100% - var(--header-height))"
  },
  "input[type=\"checkbox\"]": {
    "background-color": "rgb(from var(--mono-rgb-100) r g b/0.05)",
    "box-shadow": "inset 0 1px 2px rgb(from var(--mono-rgb-0) r g b/0.3),\n        0 1px 0 rgb(from var(--mono-rgb-100) r g b/0.05)",
    "height": "var(--checkbox-size)",
    "width": "var(--checkbox-size)"
  },
  ".workspace-leaf": {
    "background-color": "var(--background-secondary)"
  },
  ".workspace-tab-header-container": {
    "background-color": "var(--tab-container-background)",
    "padding-left": "calc(var(--size-4-2) + var(--frame-left-space))",
    "padding-right": "var(--size-4-2)",
    "height": "var(--header-height)"
  },
  ".workspace-leaf.mod-active": {
    "background-color": "var(--background-primary)"
  },
  ".inline-title": {
    "color": "var(--inline-title-color)",
    "font-family": "var(--inline-title-font)",
    "font-size": "var(--inline-title-size)",
    "font-style": "var(--inline-title-style)",
    "font-weight": "var(--inline-title-weight)",
    "line-height": "var(--inline-title-line-height)"
  }
}